# Copy this file to .env and fill in your values
# On Railway, set these as Environment Variables in the dashboard

BOT_TOKEN=your_bot_token_here
ADMIN_IDS=your_telegram_user_id_here
UPI_ID=yourname@bank
SHOP_NAME=Your Shop Name
BOT_NAME=Your Bot Name
ORDER_EXPIRY_MINUTES=5

# PostgreSQL — Railway automatically sets this when you add PostgreSQL plugin
# Leave empty for local SQLite (data stays in voucher_bot.db)
DATABASE_URL=

# Railway sets this automatically — do NOT set manually
# PORT=

# Your Railway public domain (set this after deploy to enable UPI redirect links)
# Example: my-bot.up.railway.app
RAILWAY_PUBLIC_DOMAIN=
